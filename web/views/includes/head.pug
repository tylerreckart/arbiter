  const canonical = `${siteOrigin}${canonicalPath || "/"}`
  const themeColor = "#0b0b0b"
  const shareImagePath = ogImage || defaultOgImage
  const shareImage = `${siteOrigin}${shareImagePath}`
  const shareImageAlt = ogImageAlt || defaultOgImageAlt
  const shareWidth = ogImageWidth || defaultOgImageWidth
  const shareHeight = ogImageHeight || defaultOgImageHeight
  const pageType = ogType || (variant === "docs" ? "article" : "website")
  const jsonLd = buildJsonLd({
    breadcrumbs: breadcrumbs || null,
    canonical,
    description,
    title,
    variant,
  })

