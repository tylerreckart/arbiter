extends layout.pug

block content
  .docs-shell
    include /includes/docs-sidebar.pug
    main.docs-main
      .docs-main-inner
        .doc-shell.docs-index-inner
          h1 Build, operate, and extend Arbiter.
          p.lead Start here to learn about the core concepts and features of Arbiter.
          .docs-index-list
            each card in cards
              a.docs-index-card(href=card.href)
                span.docs-index-label= card.label
                p.docs-index-blurb= card.blurb
                span.docs-index-meta #{card.count} page#{card.count === 1 ? "" : "s"}
